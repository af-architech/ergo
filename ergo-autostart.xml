<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Ergo ergonomic break reminder — runs at login, no console window.</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Enabled>true</Enabled>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!--
        IMPORTANT: Update the two paths below before importing this file.
        WorkingDirectory must be the folder containing ergo.py.
        Command must point to pythonw.exe (windowless Python).

        To find your pythonw.exe path, run in a command prompt:
          where pythonw
      -->
      <Command>pythonw.exe</Command>
      <Arguments>ergo.py</Arguments>
      <WorkingDirectory>C:\path\to\Ergo</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
